type Store struct {
	db *sql.DB
}

func Init(connectionString string) error {
	db, err := sql.Open("pgx", connectionString)
	if err != nil {
		return fmt.Errorf("open db: %w", err)
	}

	db.SetMaxOpenConns(10)
	db.SetMaxIdleConns(5)
	db.SetConnMaxLifetime(30 * time.Minute)

	ctx, cancel := context.WithTimeout(context.Background(), 5*time.Second)
	defer cancel()

	if err := db.PingContext(ctx); err != nil {
		_ = db.Close()
		return fmt.Errorf("ping db: %w", err)
	}

	Default = &Store{db: db}
	return nil
}

func (s *Store) ListPublishedArticles() []Article {
	rows, err := s.db.Query(articleSelectQuery + `
WHERE a.status = 'published'
ORDER BY a.published_at DESC NULLS LAST, a.updated_at DESC`)
	if err != nil {
		return []Article{}
	}
	defer rows.Close()

	return scanArticles(rows)
}

func (s *Store) SearchPublishedArticles(query string) []Article {
	query = strings.TrimSpace(query)
	if query == "" {
		return s.ListPublishedArticles()
	}

	rows, err := s.db.Query(articleSelectQuery+`
WHERE a.status = 'published'
  AND (
    a.title ILIKE '%' || $1 || '%'
    OR a.excerpt ILIKE '%' || $1 || '%'
    OR a.content_md ILIKE '%' || $1 || '%'
    OR a.meta_description ILIKE '%' || $1 || '%'
  )
ORDER BY a.published_at DESC NULLS LAST, a.updated_at DESC`, query)
	if err != nil {
		return []Article{}
	}
	defer rows.Close()

	return scanArticles(rows)
}

func (s *Store) GetPublishedArticleBySlug(slug string) (Article, error) {
	row := s.db.QueryRow(articleSelectQuery+`
WHERE a.status = 'published' AND a.slug = $1`, slug)

	article, err := scanArticle(row)
	if err != nil {
