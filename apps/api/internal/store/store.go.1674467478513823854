func (s *Store) listRevisionsByArticleID(articleID int64) ([]ArticleRevision, error) {
	rows, err := s.db.Query(`
SELECT id, article_id, source_type, content_md, notes, COALESCE(created_by, 0), created_at
FROM article_revisions
WHERE article_id = $1
ORDER BY created_at DESC
LIMIT 10`, articleID)
	if err != nil {
		return nil, err
	}
	defer rows.Close()

	var revisions []ArticleRevision
	for rows.Next() {
		var (
			revision  ArticleRevision
			id        int64
			createdBy int64
		)
		if err := rows.Scan(&id, &articleID, &revision.SourceType, &revision.ContentMD, &revision.Notes, &createdBy, &revision.CreatedAt); err != nil {
			continue
		}
		revision.ID = strconv.FormatInt(id, 10)
		revision.ArticleID = strconv.FormatInt(articleID, 10)
		if createdBy > 0 {
			revision.CreatedBy = strconv.FormatInt(createdBy, 10)
		}
		revisions = append(revisions, revision)
	}

	return revisions, nil
}

func (s *Store) createRevision(articleID int64, contentMD string, notes string) error {
	_, err := s.db.Exec(`
INSERT INTO article_revisions (article_id, source_type, content_md, notes)
VALUES ($1, 'manual', $2, $3)`,
		articleID,
		contentMD,
		notes,
	)
	return err
}

type articleScanner interface {
