func parseJSONMap(raw []byte) map[string]any {
	if len(raw) == 0 {
		return map[string]any{}
	}

	var value map[string]any
	if err := json.Unmarshal(raw, &value); err != nil {
		return map[string]any{}
	}

	return value
}

func parseJSONStringArray(raw []byte) []string {
	if len(raw) == 0 {
		return []string{}
	}

	var value []string
	if err := json.Unmarshal(raw, &value); err != nil {
		return []string{}
	}

	return value
}

func scanJobs(rows *sql.Rows) []Job {
	var jobs []Job
	for rows.Next() {
		var (
			job           Job
			id            int64
			articleID     int64
			payloadRaw    []byte
			resultSummary []byte
		)
		if err := rows.Scan(&id, &articleID, &job.JobType, &job.Status, &payloadRaw, &resultSummary, &job.ErrorMessage, &job.CreatedAt, &job.UpdatedAt); err != nil {
			continue
		}
		job.ID = strconv.FormatInt(id, 10)
		if articleID > 0 {
			job.ArticleID = strconv.FormatInt(articleID, 10)
		}
		job.Payload = parseJSONMap(payloadRaw)
		job.ResultSummary = parseJSONMap(resultSummary)
		jobs = append(jobs, job)
	}

	return jobs
}

func publishBlockers(article Article, latestCheck *PlagiarismCheck) []string {
	var blockers []string

	if strings.TrimSpace(article.Title) == "" {
		blockers = append(blockers, "missing title")
	}
	if strings.TrimSpace(article.Slug) == "" {
		blockers = append(blockers, "missing slug")
	}
	if strings.TrimSpace(article.MetaDescription) == "" {
		blockers = append(blockers, "missing meta description")
	}
	if strings.TrimSpace(article.CategorySlug) == "" {
		blockers = append(blockers, "missing category")
	}
	if strings.TrimSpace(article.ContentMD) == "" {
		blockers = append(blockers, "missing markdown content")
	}
	if latestCheck == nil {
		blockers = append(blockers, "missing plagiarism check")
	} else if latestCheck.Status != "pass" {
		blockers = append(blockers, "latest plagiarism check did not pass")
	}

	return blockers
}

func normalizeArticleStatus(raw string) ArticleStatus {
	switch ArticleStatus(raw) {
	case StatusIdea, StatusSourced, StatusDraft, StatusAIAssisted, StatusPlagiarismCheck, StatusReview, StatusScheduled, StatusPublished, StatusArchived:
		return ArticleStatus(raw)
	default:
		return StatusDraft
	}
}

func coalesce(value, fallback string) string {
	if strings.TrimSpace(value) == "" {
		return fallback
	}
	return value
}

func firstNonEmpty(value, fallback string) string {
	if strings.TrimSpace(value) == "" {
		return fallback
	}
	return value
}

func defaultInt(value, fallback int) int {
	if value <= 0 {
		return fallback
	}
	return value
}

func mustParseInt64(value string) int64 {
	parsed, _ := strconv.ParseInt(value, 10, 64)
	return parsed
}

