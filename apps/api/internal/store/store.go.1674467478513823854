func (s *Store) getLatestPlagiarismCheck(articleID int64) (*PlagiarismCheck, error) {
	row := s.db.QueryRow(`
SELECT article_id, status, overall_similarity_score, max_source_similarity_score, matched_sources, review_notes, checked_at
FROM plagiarism_checks
WHERE article_id = $1
ORDER BY checked_at DESC, created_at DESC
LIMIT 1`, articleID)

	var (
		check          PlagiarismCheck
		scannedID      int64
		matchedSources []byte
	)
	if err := row.Scan(&scannedID, &check.Status, &check.OverallSimilarityScore, &check.MaxSourceSimilarityScore, &matchedSources, &check.ReviewNotes, &check.CheckedAt); err != nil {
		if errors.Is(err, sql.ErrNoRows) {
			return nil, ErrNotFound
		}
		return nil, err
	}

	check.ArticleID = strconv.FormatInt(scannedID, 10)
	check.MatchedSources = parseJSONStringArray(matchedSources)
	return &check, nil
}

