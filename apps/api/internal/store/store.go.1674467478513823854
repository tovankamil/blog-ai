func (s *Store) EnqueueJob(articleID, jobType string, payload map[string]any) (Job, error) {
	id, err := strconv.ParseInt(articleID, 10, 64)
	if err != nil {
		return Job{}, ErrValidation
	}

	if _, err := s.getArticleByID(id); err != nil {
		return Job{}, err
	}

	payloadJSON, _ := json.Marshal(payload)
	resultJSON, _ := json.Marshal(map[string]any{"message": "queued for worker processing"})

	row := s.db.QueryRow(`
INSERT INTO content_jobs (article_id, job_type, status, payload, result_summary)
VALUES ($1, $2, 'queued', $3::jsonb, $4::jsonb)
RETURNING id, created_at, updated_at`, id, jobType, string(payloadJSON), string(resultJSON))

	var jobID int64
	var createdAt time.Time
	var updatedAt time.Time
	if err := row.Scan(&jobID, &createdAt, &updatedAt); err != nil {
		return Job{}, err
	}

	return Job{
		ID:            strconv.FormatInt(jobID, 10),
		ArticleID:     articleID,
		JobType:       jobType,
		Status:        "queued",
		Payload:       payload,
		ResultSummary: map[string]any{"message": "queued for worker processing"},
		CreatedAt:     createdAt,
		UpdatedAt:     updatedAt,
	}, nil
}

