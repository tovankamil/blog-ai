}

func scanArticle(scanner articleScanner) (Article, error) {
	var (
		article      Article
		id           int64
		categoryID   sql.NullInt64
		authorID     sql.NullInt64
		categorySlug sql.NullString
		publishedAt  sql.NullTime
	)

	err := scanner.Scan(
		&id,
		&article.Title,
		&article.Slug,
		&article.Excerpt,
		&article.ContentMD,
		&article.ContentHTML,
		&article.Status,
		&categoryID,
		&categorySlug,
		&authorID,
		&article.MetaTitle,
		&article.MetaDescription,
		&article.CoverImageURL,
		&publishedAt,
		&article.CreatedAt,
		&article.UpdatedAt,
	)
	if err != nil {
		return Article{}, err
	}

	article.ID = strconv.FormatInt(id, 10)
	if categoryID.Valid {
		article.CategoryID = strconv.FormatInt(categoryID.Int64, 10)
	}
	if categorySlug.Valid {
		article.CategorySlug = categorySlug.String
	}
	if authorID.Valid {
		article.AuthorID = strconv.FormatInt(authorID.Int64, 10)
	}
	if publishedAt.Valid {
		article.PublishedAt = &publishedAt.Time
	}

	return article, nil
