func (s *Store) ListTrendCandidates() []TrendCandidate {
	rows, err := s.db.Query(`
SELECT
	sr.title,
	COALESCE(MAX(sr.trend_score)::int, 0) AS trend_score,
	COUNT(DISTINCT sr.source_id) AS approved_sources,
	COALESCE(string_agg(sr.url, ',' ORDER BY sr.trend_score DESC), '') AS urls
FROM source_records sr
JOIN sources s ON s.id = sr.source_id
WHERE s.review_status = 'approved'
GROUP BY sr.title
ORDER BY MAX(sr.trend_score) DESC, sr.title ASC
LIMIT 20`)
	if err != nil {
		return []TrendCandidate{}
	}
	defer rows.Close()

	var trends []TrendCandidate
	for rows.Next() {
		var (
			trend TrendCandidate
			urls  string
		)
		if err := rows.Scan(&trend.Topic, &trend.TrendScore, &trend.ApprovedSources, &urls); err != nil {
			continue
		}
		if urls != "" {
			trend.SourceRecordURLs = strings.Split(urls, ",")
		} else {
			trend.SourceRecordURLs = []string{}
		}
		trends = append(trends, trend)
	}

	return trends
}

