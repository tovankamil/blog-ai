func (s *Store) ListCategories() []Category {
	rows, err := s.db.Query(`
SELECT id, name, slug, description, created_at, updated_at
FROM categories
ORDER BY name ASC`)
	if err != nil {
		return []Category{}
	}
	defer rows.Close()

	var categories []Category
	for rows.Next() {
		var (
			category Category
			id       int64
		)
		if err := rows.Scan(&id, &category.Name, &category.Slug, &category.Description, &category.CreatedAt, &category.UpdatedAt); err != nil {
			continue
		}
		category.ID = strconv.FormatInt(id, 10)
		categories = append(categories, category)
	}

	return categories
}

func (s *Store) ListPublishedArticlesByCategory(slug string) ([]Article, error) {
	rows, err := s.db.Query(articleSelectQuery+`
WHERE a.status = 'published' AND c.slug = $1
ORDER BY a.published_at DESC NULLS LAST, a.updated_at DESC`, slug)
	if err != nil {
		return nil, err
	}
	defer rows.Close()

	articles := scanArticles(rows)
	if len(articles) > 0 {
		return articles, nil
	}

	var exists bool
	if err := s.db.QueryRow(`SELECT EXISTS (SELECT 1 FROM categories WHERE slug = $1)`, slug).Scan(&exists); err != nil {
		return nil, err
	}
	if !exists {
		return nil, ErrNotFound
	}

	return []Article{}, nil
}

